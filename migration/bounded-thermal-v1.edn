{:schema "kotoba-ic-packaging-migration/v1"
 :profile :ic-packaging/bounded-thermal-v1
 :legacy {:source "src/ic_packaging/thermal.cljc"
          :status :retained-general-oracle}
 :canonical {:engine-and-conformance "src/ic_packaging/bounded_thermal.kotoba"}
 :domain
 {:functions [:theta-ca-effective-airflow :thermal-from-effective
              :thermal-junction-temp-c :thermal-case-temp-c :thermal-theta-ja]
  :formula "simple thermal resistance network: Tj = Ta + P*(theta_jc +
           theta_ca_eff), Tc = Ta + P*theta_ca_eff; forced airflow scales
           theta_ca by the empirical 1/sqrt(1+velocity) factor. Split
           into two <=4-param functions (theta_ca_effective computed
           separately from the main formula) to avoid the known
           kotoba-lang/compiler Wasm-lowering bug for functions with 5+
           :f64 parameters (mining-pool's bounded_vardiff.kotoba /
           kotoba-lang/compiler#206) -- calculate-thermal's original 5
           inputs (power/ambient/theta_jc/theta_ca/airflow) would have
           hit exactly that boundary."}
 :excluded [:ic-packaging.package :ic-packaging.bonding]
 :exclusion-reason "not reviewed this pass; thermal.cljc was
                    self-contained (no requires) and a clean, small,
                    high-value target on its own. bonding.cljc's
                    generate-bond-diagram operates on arbitrary-length
                    vectors of pad records (same bounded-arbitrary-
                    collection gap already found for search/sheets/
                    atprotocol) and was not attempted."
 :verification
 {:legacy {:tests 6 :assertions 10 :failures 0 :errors 0}
  :hand-verified-cases
  "case A mirrors ic_packaging_test.cljc's
   thermal-junction-temp-above-ambient test exactly (power=2.0
   ambient=25.0 theta_jc=5.0 theta_ca=20.0, no airflow -> junction=75.0
   case=65.0 theta_ja=25.0); case B mirrors airflow-reduces-theta-ja
   (adds exact expected float values, not just the inequality the
   legacy test checks); case C is a third independently-computed
   airflow configuration. All three were computed with a Python
   re-implementation of the identical formula before compiling and
   compared bit-exact via f64-to-bits (kotoba-lang/compiler's =
   does not admit raw :f64 operands) -- f64-sqrt agreeing bit-for-bit
   with Python's math.sqrt relies on IEEE-754 requiring sqrt to be
   correctly rounded, which any conformant implementation (JS
   Math.sqrt, Wasm f64.sqrt, Python's libm) satisfies for the same
   input"
  :web {:main 42 :required-capabilities []}
  :wasm {:main 42}
  :required-capabilities []
  :local-verification
  {:clojure-test {:tests 6 :assertions 10 :failures 0 :errors 0}
   :lint {:errors 0 :warnings 0}
   :kotoba-compile [:js-browser :wasm32-browser]
   :kotoba-conformance :passed-both-targets}}
 :cutover {:bounded-profile-authorized true :general-cljc-oracle-retained true}}
